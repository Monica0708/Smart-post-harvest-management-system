# ============================================================
#  HarvestGuard – Environment Configuration
#  Fill in your API keys below before running the app
# ============================================================

# ── Flask ────────────────────────────────────────────────────
SECRET_KEY=harvestguard-secret-change-me-in-production
FLASK_ENV=development
PORT=5000

# ── data.gov.in (AGMARKNET real-time mandi prices) ───────────
# Get free key at: https://data.gov.in/user/register
# Resource ID for daily mandi prices: 9ef84268-d588-465a-a308-a864a43d0070
DATA_GOV_API_KEY=YOUR_DATA_GOV_IN_API_KEY_HERE

# ── eNAM API (National Agriculture Market) ───────────────────
# Register at: https://enam.gov.in/web/
ENAM_API_KEY=YOUR_ENAM_API_KEY_HERE

# ── Twilio SMS Alerts ─────────────────────────────────────────
# Get free trial at: https://www.twilio.com/try-twilio
# Free trial gives you $15 credit (~500 SMS)
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── Claude AI (Chatbot) ───────────────────────────────────────
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# ── Price Refresh Interval (minutes) ─────────────────────────
PRICE_REFRESH_MINUTES=30
SMS_ALERT_HOUR=7